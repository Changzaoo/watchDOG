DATABASE_URL="file:./sentinelscope.db"
PORT=3001
NODE_ENV=development
ENABLE_LOCAL_SCANS=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Preferido: cole o JSON completo da service account em uma linha
FIREBASE_SERVICE_ACCOUNT_JSON=
# Alternativa: JSON da service account em base64
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=

# Alternativa legada: campos separados da service account
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Web API key do Firebase Auth (Project settings > General > Web API Key)
FIREBASE_WEB_API_KEY=
AUTH_REQUIRED=false
AUTH_ALLOWED_EMAILS=
