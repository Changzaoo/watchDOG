generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Scan {
  id          String   @id @default(cuid())
  type        String
  target      String
  projectName String
  score       Int      @default(0)
  status      String   @default("pending")
  startedAt   DateTime @default(now())
  finishedAt  DateTime?
  durationMs  Int?
  techStack   String   @default("[]")
  summary     String   @default("{}")
  findings    Finding[]
  logs        ScanLog[]
  threatModel ThreatModel?
  defenseLayers DefenseLayer[]
  createdAt   DateTime @default(now())
}

model Finding {
  id                      String   @id @default(cuid())
  scanId                  String
  ruleId                  String
  title                   String
  severity                String
  category                String
  confidence              String   @default("medium")
  filePath                String?
  url                     String?
  line                    Int?
  evidenceMasked          String?
  description             String
  impact                  String
  attackScenarioDefensive String?
  remediation             String
  safeExample             String?
  fixPrompt               String?
  testSuggestion          String?
  reference               String?
  status                  String   @default("open")
  userNote                String?
  occurrences             Int      @default(1)
  createdAt               DateTime @default(now())
  scan                    Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
}

model ScanLog {
  id        String   @id @default(cuid())
  scanId    String
  level     String
  message   String
  createdAt DateTime @default(now())
  scan      Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
}

model ThreatModel {
  id             String @id @default(cuid())
  scanId         String @unique
  assets         String @default("[]")
  attackers      String @default("[]")
  attackSurfaces String @default("[]")
  controls       String @default("[]")
  gaps           String @default("[]")
  createdAt      DateTime @default(now())
  scan           Scan   @relation(fields: [scanId], references: [id], onDelete: Cascade)
}

model DefenseLayer {
  id          String @id @default(cuid())
  scanId      String
  name        String
  status      String @default("unknown")
  issuesCount Int    @default(0)
  summary     String @default("")
  createdAt   DateTime @default(now())
  scan        Scan   @relation(fields: [scanId], references: [id], onDelete: Cascade)
}

model RuleConfig {
  id               String   @id @default(cuid())
  ruleId           String   @unique
  enabled          Boolean  @default(true)
  severityOverride String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
