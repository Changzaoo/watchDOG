# watchDOG - variaveis de ambiente

# Backend publico
DATABASE_URL="file:./sentinelscope.db"
PORT=3001
HOST=0.0.0.0
NODE_ENV=production
PUBLIC_BACKEND=true
ENABLE_LOCAL_SCANS=false
CORS_ORIGINS=https://watchdog-chi.vercel.app

# Firebase Auth - valores reais ficam somente no ambiente do backend
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_WEB_API_KEY=
AUTH_REQUIRED=true

# Protecao do login: tentativas invalidas por email e IP antes do bloqueio progressivo.
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_MINUTES=15
LOGIN_LOCKOUT_MINUTES=15
LOGIN_MAX_LOCKOUT_MINUTES=60
