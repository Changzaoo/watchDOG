# watchDOG - variaveis de ambiente

# Backend local
DATABASE_URL="file:./sentinelscope.db"
PORT=3001
NODE_ENV=development
ENABLE_LOCAL_SCANS=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend local: destino do proxy do Vite
VITE_API_TARGET=http://localhost:3001

# Opcional: chamada direta do browser para o backend.
# Em producao na Vercel, prefira os rewrites /api e /health do vercel.json.
# VITE_USE_DIRECT_API=true
# VITE_API_URL=https://watchdog-to6v.onrender.com
