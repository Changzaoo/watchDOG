# watchDOG - variaveis de ambiente

# Backend local
DATABASE_URL="file:./sentinelscope.db"
PORT=3001
NODE_ENV=development
ENABLE_LOCAL_SCANS=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Firebase Auth - valores reais ficam somente no ambiente do backend
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_WEB_API_KEY=
AUTH_REQUIRED=false

# Opcional: limite o acesso a emails existentes no Firebase, separados por virgula.
# Se ficar vazio, qualquer usuario existente no projeto Firebase consegue entrar.
AUTH_ALLOWED_EMAILS=
